@page "/trivia"

@using Microsoft.AspNetCore.SignalR.Client

@inject BlazorApp.Data.GameSessionService GameSessionService
@inject NavigationManager NavigationManager

<PageTitle>Trivia Quiz</PageTitle>

<h1>Trivia Quiz Game</h1>

<p>Enter player names (comma separated):</p>
<input @bind="playerNamesInput" class="form-control" />
<button class="btn btn-primary mt-2" @onclick="StartGame">Start Game</button>

<p>
    <button class="btn btn-success me-2" @onclick="ShowHostPanel">Host Game</button>
    <button class="btn btn-info" @onclick="ShowJoinPanel">Join Game</button>
</p>

@if (showHostPanel)
{
    <div class="card card-body mb-3">
        <h4>Host a Game</h4>
        <input @bind="hostName" placeholder="Host name" class="form-control mb-2" />
        <button class="btn btn-primary" @onclick="HostGame">Start Hosting</button>
        @if (!string.IsNullOrEmpty(gameCode))
        {
            <div class="alert alert-success mt-2">
                Game Code: <b>@gameCode</b><br />
                Share this code with players to join.
            </div>
        }
    </div>
}

@if (showJoinPanel)
{
    <div class="card card-body mb-3">
        <h4>Join a Game</h4>
        <input @bind="joinName" placeholder="Your name" class="form-control mb-2" />
        <input @bind="joinCode" placeholder="Game code" class="form-control mb-2" />
        <button class="btn btn-primary" @onclick="JoinGame">Join</button>
        @if (!string.IsNullOrEmpty(joinError))
        {
            <div class="alert alert-danger mt-2">@joinError</div>
        }
    </div>
}

@if (session != null)
{
    <h3>Game Lobby</h3>
    <p>Game Code: <b>@gameCode</b></p>
    <ul>
        @foreach (var p in session.Players)
        {
            <li>@p</li>
        }
    </ul>
    @if (isHost)
    {
        <button class="btn btn-success" @onclick="StartGameForSession">Start Game</button>
    }
}

@if (players.Count > 0)
{
    <h3>Players:</h3>
    <ul>
        @foreach (var player in players)
        {
            <li>@player.Name - Score: @player.Score</li>
        }
    </ul>

    @if (currentQuestion != null)
    {
        <h4>Question @(@currentQuestionIndex + 1): @currentQuestion.Text</h4>
        <ul>
            @foreach (var answer in currentQuestion.Answers)
            {
                <li>
                    <button class="btn btn-outline-secondary mb-1" @onclick="() => SubmitAnswer(answer)">@answer</button>
                </li>
            }
        </ul>
        <p>Current Player: <b>@players[currentPlayerIndex].Name</b></p>
        @if (!string.IsNullOrEmpty(feedback))
        {
            <div class="alert alert-info">@feedback</div>
        }
    }
    else if (players.Count > 0)
    {
        <h4>Game Over!</h4>
        <ul>
            @foreach (var player in players.OrderByDescending(p => p.Score))
            {
                <li>@player.Name - Score: @player.Score</li>
            }
        </ul>
    }
}

@if (showQuestionPanel)
{
    <div class="card card-body mb-3">
        <h4>Ask Question</h4>
        <input @bind="newQuestionText" placeholder="Question text" class="form-control mb-2" />
        <input @bind="newAnswersInput" placeholder="Answers (comma separated)" class="form-control mb-2" />
        <button class="btn btn-primary" @onclick="SendQuestionToPlayers">Send Question</button>
    </div>
}

@if (currentLiveQuestion != null && (!isHost || (isHost && liveAnswers.Count > 0)))
{
    <div class="card card-body mb-3">
        <h4>Live Question: @currentLiveQuestion.Text</h4>
        <ul>
            @foreach (var ans in currentLiveQuestion.Answers)
            {
                <li>
                    <button class="btn btn-outline-secondary mb-1" @onclick="() => SendAnswerToHost(ans)" disabled="@(isHost)">@ans</button>
                </li>
            }
        </ul>
        <h5>Answers Received:</h5>
        <ul>
            @foreach (var entry in liveAnswers)
            {
                <li>@entry.Key: @entry.Value</li>
            }
        </ul>
    </div>
}

@code {
    private string playerNamesInput = string.Empty;
    private List<Player> players = new();
    private int currentPlayerIndex = 0;
    private int currentQuestionIndex = 0;
    private string feedback = string.Empty;

    private List<Question> questions = new()
    {
        new Question("What is the capital of France?", new[] { "Paris", "London", "Berlin", "Rome" }, "Paris"),
        new Question("Which planet is known as the Red Planet?", new[] { "Earth", "Mars", "Jupiter", "Venus" }, "Mars"),
        new Question("Who wrote 'Hamlet'?", new[] { "Shakespeare", "Dickens", "Austen", "Tolkien" }, "Shakespeare"),
        new Question("What is 5 x 6?", new[] { "30", "11", "56", "20" }, "30"),
    };

    private Question? currentQuestion => currentQuestionIndex < questions.Count ? questions[currentQuestionIndex] : null;

    private bool showHostPanel, showJoinPanel;
    private string hostName = string.Empty, gameCode = string.Empty;
    private string joinName = string.Empty, joinCode = string.Empty, joinError = string.Empty;
    private BlazorApp.Data.GameSession? session;
    private bool isHost = false;
    private HubConnection? hubConnection;

    private bool showQuestionPanel = false;
    private string newQuestionText = string.Empty, newAnswersInput = string.Empty;
    private LiveQuestion? currentLiveQuestion;
    private Dictionary<string, string> liveAnswers = new();

    private class LiveQuestion
    {
        public string Text { get; set; } = string.Empty;
        public string[] Answers { get; set; } = Array.Empty<string>();
    }

    protected override async Task OnInitializedAsync()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/triviahub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<string>("PlayerJoined", (playerName) =>
        {
            if (session != null && !session.Players.Contains(playerName))
            {
                session.Players.Add(playerName);
                StateHasChanged();
            }
        });
        hubConnection.On("PlayerListChanged", () =>
        {
            StateHasChanged();
        });
        hubConnection.On("GameStarted", async () =>
        {
            if (isHost)
            {
                await StartGameForSession();
            }
            else
            {
                // For players, fetch the latest player list and start game
                if (session != null)
                {
                    players = session.Players.Select(n => new Player(n)).ToList();
                    currentPlayerIndex = 0;
                    currentQuestionIndex = 0;
                    feedback = string.Empty;
                    session = null;
                }
            }
            StateHasChanged();
        });
        hubConnection.On<string, string[]>("ReceiveQuestion", (questionText, answers) =>
        {
            currentLiveQuestion = new LiveQuestion { Text = questionText, Answers = answers };
            liveAnswers.Clear();
            StateHasChanged();
        });
        hubConnection.On<string, string>("ReceiveAnswer", (playerName, answer) =>
        {
            liveAnswers[playerName] = answer;
            StateHasChanged();
        });
        await hubConnection.StartAsync();
    }

    private async Task HostGame()
    {
        if (!string.IsNullOrWhiteSpace(hostName))
        {
            gameCode = GameSessionService.CreateSession(hostName);
            session = GameSessionService.GetSession(gameCode);
            isHost = true;
            if (hubConnection != null)
            {
                await hubConnection.InvokeAsync("JoinGame", gameCode, hostName);
            }
        }
    }

    private async Task JoinGame()
    {
        if (GameSessionService.JoinSession(joinCode, joinName))
        {
            session = GameSessionService.GetSession(joinCode);
            gameCode = joinCode;
            isHost = false;
            joinError = string.Empty;
            if (hubConnection != null)
            {
                await hubConnection.InvokeAsync("JoinGame", joinCode, joinName);
                await hubConnection.InvokeAsync("PlayerListChanged", joinCode);
            }
        }
        else
        {
            joinError = "Invalid game code or name.";
        }
    }

    private async Task StartGameForSession()
    {
        if (session != null)
        {
            players = session.Players.Select(n => new Player(n)).ToList();
            currentPlayerIndex = 0;
            currentQuestionIndex = 0;
            feedback = string.Empty;
            session = null; // Hide lobby
            showQuestionPanel = isHost;
            if (hubConnection != null)
            {
                await hubConnection.InvokeAsync("GameStarted", gameCode);
            }
        }
    }

    private void StartGame()
    {
        players = playerNamesInput.Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(name => new Player(name.Trim())).ToList();
        currentPlayerIndex = 0;
        currentQuestionIndex = 0;
        feedback = string.Empty;
    }

    private void SubmitAnswer(string answer)
    {
        if (currentQuestion == null) return;
        var player = players[currentPlayerIndex];
        if (answer == currentQuestion.CorrectAnswer)
        {
            player.Score++;
            feedback = $"Correct, {player.Name}!";
        }
        else
        {
            feedback = $"Wrong, {player.Name}. The correct answer was {currentQuestion.CorrectAnswer}.";
        }
        currentPlayerIndex = (currentPlayerIndex + 1) % players.Count;
        if (currentPlayerIndex == 0)
        {
            currentQuestionIndex++;
        }
    }

    private async Task SendQuestionToPlayers()
    {
        if (hubConnection != null && !string.IsNullOrWhiteSpace(newQuestionText) && !string.IsNullOrWhiteSpace(newAnswersInput))
        {
            var answers = newAnswersInput.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(a => a.Trim()).ToArray();
            await hubConnection.InvokeAsync("SendQuestion", gameCode, newQuestionText, answers);
            // Only set currentLiveQuestion for host, not for all
            if (isHost)
            {
                currentLiveQuestion = new LiveQuestion { Text = newQuestionText, Answers = answers };
                liveAnswers.Clear();
                StateHasChanged();
            }
        }
    }

    private async Task SendAnswerToHost(string answer)
    {
        if (hubConnection != null && currentLiveQuestion != null)
        {
            await hubConnection.InvokeAsync("SendAnswer", gameCode, isHost ? hostName : joinName, answer);
        }
    }

    private void ShowHostPanel()
    {
        showHostPanel = !showHostPanel;
        showJoinPanel = false;
    }

    private void ShowJoinPanel()
    {
        showJoinPanel = !showJoinPanel;
        showHostPanel = false;
    }

    public class Player
    {
        public string Name { get; set; }
        public int Score { get; set; }
        public Player(string name) { Name = name; Score = 0; }
    }

    public class Question
    {
        public string Text { get; set; }
        public string[] Answers { get; set; }
        public string CorrectAnswer { get; set; }
        public Question(string text, string[] answers, string correctAnswer)
        {
            Text = text;
            Answers = answers;
            CorrectAnswer = correctAnswer;
        }
    }
}
